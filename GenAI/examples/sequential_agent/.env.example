# ─── Microsoft Azure AI Foundry ───────────────────────────────────────────────
# Get your project endpoint from:
#   Azure Portal → AI Foundry → Your Project → Settings → Overview
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>

# The deployment name of the model you want to use (e.g., gpt-4o, gpt-4o-mini)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ─── Authentication ────────────────────────────────────────────────────────────
# This project uses DefaultAzureCredential.
# Run `az login` in your terminal — no extra config needed for local development.
# For production, use Managed Identity or a Service Principal.

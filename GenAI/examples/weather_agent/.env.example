OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# NWS User-Agent (REQUIRED by weather.gov — use your real contact info)
NWS_USER_AGENT=WeatherForecastAgent/1.0 (your-app-name; your-email@example.com)

# Polling intervals (seconds)
ALERT_POLL_INTERVAL=300       # 5 minutes — check for new alerts
FORECAST_POLL_INTERVAL=1800   # 30 minutes — refresh 7-day forecasts
HOURLY_POLL_INTERVAL=3600     # 1 hour — refresh hourly forecasts

# Monitored locations: "lat,lon,Name;lat,lon,Name;..."
WEATHER_LOCATIONS=40.7128,-74.0060,New York NY;34.0522,-118.2437,Los Angeles CA;41.8781,-87.6298,Chicago IL;29.7604,-95.3698,Houston TX;33.4484,-112.0740,Phoenix AZ

# Minimum alert severity to auto-generate AI safety guidelines
# Options: Extreme, Severe, Moderate, Minor
AUTO_GUIDELINE_SEVERITY=Moderate

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
